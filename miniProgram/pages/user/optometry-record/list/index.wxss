.page { padding: 12px; }
.loading, .empty { color: #888; font-size: 14px; padding: 16px; text-align: center; }
.card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 12px; margin-bottom: 12px; }
.row { display: flex; justify-content: space-between; padding: 6px 0; }
.label { color: #666; }
.value { color: #333; }
.segmented { display: flex; gap: 8px; margin: 4px 0 12px; }
.segment { padding: 6px 12px; border: 1px solid #ddd; border-radius: 16px; color: #666; font-size: 14px; }
.segment.active { background: #1989fa; border-color: #1989fa; color: #fff; }
.chart-card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 8px 8px 12px; margin-bottom: 12px; }
.chart-title { font-size: 14px; color: #333; margin-bottom: 4px; }
.chart-legend { display: flex; justify-content: flex-end; gap: 12px; margin-top: 4px; }
.legend-item { display: flex; align-items: center; }
.legend-color { width: 12px; height: 2px; margin-right: 4px; }
.legend-right { background: #1989fa; }
.legend-left { background: #ff9900; }
.legend-text { font-size: 12px; color: #666; }
.chart-detail-card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 10px 12px; margin-top: 4px; font-size: 12px; }
.detail-title { font-size: 13px; color: #333; margin-bottom: 6px; }
.detail-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
.detail-label { color: #666; width: 70px; }
.detail-value { color: #333; flex: 1; text-align: right; margin-left: 8px; }
