.door-page-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f6f8fa;
  padding: 40rpx 20rpx;
}
.door-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 20rpx;
}
.door-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
  text-align: center;
}
.door-btn {
  width: 40vw;
  height: 40vw;        
  border-radius: 50%;
  font-size: 46rpx;
  color:#fff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #39B54B;
}