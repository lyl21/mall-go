<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <block wx:elif="{{header}}">
    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="grid">
        <view class="cell"><text class="label">顾客</text><text class="value">{{header.customerName}}</text></view>
        <view class="cell"><text class="label">验光师</text><text class="value">{{header.optometristName}}</text></view>
        <view class="cell"><text class="label">门店</text><text class="value">{{header.storeName}}</text></view>
        <view class="cell"><text class="label">电话</text><text class="value">{{header.storePhone}}</text></view>
        <view class="cell"><text class="label">时间</text><text class="value">{{header.createTime}}</text></view>
      </view>
    </view>



    <view class="segmented">
      <view class="segment {{useType==='far'?'active':''}}" data-type="far" bindtap="switchUseType">远用</view>
      <view class="segment {{useType==='near'?'active':''}}" data-type="near" bindtap="switchUseType">近用</view>
    </view>

    <view class="section" wx:if="{{listById.length}}">
      <view class="section-title">验光仪</view>
      <view class="table">
        <view class="thead">
          <text class="th">项目</text>
          <text class="th">右眼</text>
          <text class="th">左眼</text>
        </view>
        <block wx:for="{{listById}}" wx:key="prop">
          <view class="tr">
            <text class="td">{{item.label || '-'}}</text>
            <text class="td">{{item.dataRt1 || item.dataRt2 || '-'}}</text>
            <text class="td">{{item.dataLt1 || item.dataLt2 || '-'}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="section" wx:if="{{headT2.length}}">
      <view class="section-title">验光头/最终配镜</view>
      <view class="table">
        <view class="thead">
          <text class="th">项目</text>
          <text class="th">右眼</text>
          <text class="th">左眼</text>
        </view>
        <block wx:for="{{headT2}}" wx:key="prop">
          <view class="tr">
            <text class="td">{{item.label}}</text>
            <text class="td">{{useType==='far' ? (item.dataRf || '-') : (item.dataRn || '-')}}</text>
            <text class="td">{{useType==='far' ? (item.dataLf || '-') : (item.dataLn || '-')}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- <view class="section" wx:if="{{ finalT3.length}}">
      <view class="section-title">最终配镜</view>
      <view class="table">
        <view class="thead">
          <text class="th">项目</text>
          <text class="th">右眼</text>
          <text class="th">左眼</text>
        </view>
        <block wx:for="{{finalT3}}" wx:key="prop">
          <view class="tr">
            <text class="td">{{item.label}}</text>
            <text class="td">{{useType==='far' ? (item.dataRf || '-') : (item.dataRn || '-')}}</text>
            <text class="td">{{useType==='far' ? (item.dataLf || '-') : (item.dataLn || '-')}}</text>
          </view>
        </block>
      </view>
    </view> -->


    <view class="section" wx:if="{{aiData}}">
      <view class="section-title">AI分析</view>
      <view class="ai-content">{{aiData}}</view>
    </view>


    <view class="section" wx:if="{{sheetTwo}}">
      <view class="section-header">
        <view class="section-title">验光单二</view>
        <text class="more-btn" bindtap="toggleSheetTwo">{{showSheetTwo ? '收起' : '更多'}}</text>
      </view>
      <block wx:if="{{showSheetTwo}}">
        <view class="sub-title">视力检查结果</view>
        <view class="segmented">
          <view class="segment {{sheetUseType==='far'? 'active': ''}}" data-type="far" bindtap="switchSheetUseType">远用</view>
          <view class="segment {{sheetUseType==='near'? 'active': ''}}" data-type="near" bindtap="switchSheetUseType">近用</view>
        </view>
        <view class="table" wx:if="{{visionResultNeutral.length}}">
          <view class="thead">
            <text class="th">检查项目</text>
            <text class="th">检查结果</text>
            <text class="th">参考值</text>
          </view>
          <block wx:for="{{visionResultNeutral}}" wx:key="label">
            <view class="tr">
              <text class="td">{{item.label}}</text>
              <text class="td">{{item.value}}</text>
              <text class="td">{{item.ref || '-'}}</text>
            </view>
          </block>
        </view>
        <view class="table" wx:if="{{sheetUseType==='far' && visionResultFar.length}}">
          <view class="thead">
            <text class="th">检查项目</text>
            <text class="th">检查结果</text>
            <text class="th">参考值</text>
          </view>
          <block wx:for="{{visionResultFar}}" wx:key="label">
            <view class="tr">
              <text class="td">{{item.label}}</text>
              <text class="td">{{item.value}}</text>
              <text class="td">{{item.ref || '-'}}</text>
            </view>
          </block>
        </view>
        <view class="table" wx:if="{{sheetUseType==='near' && visionResultNear.length}}">
          <view class="thead">
            <text class="th">检查项目</text>
            <text class="th">检查结果</text>
            <text class="th">参考值</text>
          </view>
          <block wx:for="{{visionResultNear}}" wx:key="label">
            <view class="tr">
              <text class="td">{{item.label}}</text>
              <text class="td">{{item.value}}</text>
              <text class="td">{{item.ref || '-'}}</text>
            </view>
          </block>
        </view>
        <view class="grid" wx:if="{{!visionResultNeutral.length && !visionResultFar.length && !visionResultNear.length}}">
          <view class="cell"><text class="label">WW4点</text><text class="value">{{sheetTwo.visionTestResults.ww4points || '-'}} </text></view>
          <view class="cell"><text class="label">NRA</text><text class="value">{{sheetTwo.visionTestResults.nra || '-'}} </text></view>
          <view class="cell"><text class="label">PRA</text><text class="value">{{sheetTwo.visionTestResults.pra || '-'}} </text></view>
          <view class="cell"><text class="label">右眼视力</text><text class="value">{{sheetTwo.visionTestResults.rightEyeVision || '-'}} </text></view>
          <view class="cell"><text class="label">左眼视力</text><text class="value">{{sheetTwo.visionTestResults.leftEyeVision || '-'}} </text></view>
          <view class="cell"><text class="label">双眼视力</text><text class="value">{{sheetTwo.visionTestResults.binocularVision || '-'}} </text></view>
          <view class="cell"><text class="label">诊断</text><text class="value">{{sheetTwo.visionTestResults.diagnosisName || '-'}} </text></view>
        </view>
        <view class="divider"></view>
        <view class="sub-title">调节灵活度 Accmmodative Faccility</view>
        <view class="table">
          <view class="thead">
            <text class="th">检查项目</text>
            <text class="th">检查结果</text>
            <text class="th">参考值</text>
          </view>
          <view class="tr">
            <text class="td">采用检查的反转</text>
            <text class="td">{{sheetTwo.visionTestResults.reverseBeat || '-'}}</text>
            <text class="td">-</text>
          </view>
          <view class="tr">
            <text class="td">视力表</text>
            <text class="td">{{sheetTwo.visionTestResults.visualChart || '-'}}</text>
            <text class="td">-</text>
          </view>
          <view class="tr">
            <text class="td">双眼(D)</text>
            <text class="td">{{sheetTwo.visionTestResults.binoculus || '-'}}</text>
            <text class="td">-</text>
          </view>
          <view class="tr">
            <text class="td">右眼(R)</text>
            <text class="td">{{sheetTwo.visionTestResults.rightEye || '-'}}</text>
            <text class="td">-</text>
          </view>
          <view class="tr">
            <text class="td">左眼(L)</text>
            <text class="td">{{sheetTwo.visionTestResults.leftEye || '-'}}</text>
            <text class="td">-</text>
          </view>
        </view>
        <view class="sub-title">参考值（采用 2.00 / 20 / 30 检测）</view>
        <view class="table">
          <view class="thead">
            <text class="th">年龄</text>
            <text class="th">标准值(双眼)</text>
            <text class="th">标准值(单眼)</text>
          </view>
          <view class="tr">
            <text class="td">8~12</text>
            <text class="td">5cpm</text>
            <text class="td">7cpm</text>
          </view>
          <view class="tr">
            <text class="td">13~30</text>
            <text class="td">8cpm</text>
            <text class="td">11cpm</text>
          </view>
        </view>
        <view class="divider"></view>
        <view class="sub-title">试戴验光（摘要）</view>
        <view class="table table-try">
          <view class="thead">
            <text class="th">眼别</text>
            <text class="th">球镜</text>
            <text class="th">柱镜</text>
            <text class="th">轴位</text>
            <text class="th">加光</text>
            <text class="th">瞳距</text>
            <text class="th">棱镜</text>
            <text class="th">方向</text>
          </view>
          <view class="tr">
            <text class="td">右眼(R)</text>
            <text class="td">{{(tryOptometryR && tryOptometryR.sphericalMirror) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.cylindricalMirror) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.positionOfAxis) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.addend) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.pupilDistance) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.prismDiopter) || '-'}} </text>
            <text class="td">{{(tryOptometryR && tryOptometryR.prismDirection) || '-'}} </text>
          </view>
          <view class="tr">
            <text class="td">左眼(L)</text>
            <text class="td">{{(tryOptometryL && tryOptometryL.sphericalMirror) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.cylindricalMirror) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.positionOfAxis) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.addend) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.pupilDistance) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.prismDiopter) || '-'}} </text>
            <text class="td">{{(tryOptometryL && tryOptometryL.prismDirection) || '-'}} </text>
          </view>
        </view>
        <view class="segmented">
          <view class="segment" bindtap="toggleTryHistory">{{showTryHistory ? '收起历史记录' : '展开历史记录'}}</view>
        </view>
        <block wx:if="{{showTryHistory}}">
          <view class="sub-title">试戴验光（历史）</view>
          <view class="table table-try">
            <view class="thead">
              <text class="th">眼别</text>
              <text class="th">球镜</text>
              <text class="th">柱镜</text>
              <text class="th">轴位</text>
              <text class="th">加光</text>
              <text class="th">瞳距</text>
              <text class="th">棱镜</text>
              <text class="th">方向</text>
            </view>
            <block wx:for="{{sheetTwo.tryOptometryList || []}}" wx:key="tryOptometryId">
              <view class="tr" wx:if="{{item}}">
                <text class="td">{{item.leftRightEyes === 1 ? '右眼(R)' : '左眼(L)'}} </text>
                <text class="td">{{item.sphericalMirror || '-'}} </text>
                <text class="td">{{item.cylindricalMirror || '-'}} </text>
                <text class="td">{{item.positionOfAxis || '-'}} </text>
                <text class="td">{{item.addend || '-'}} </text>
                <text class="td">{{item.pupilDistance || '-'}} </text>
                <text class="td">{{item.prismDiopter || '-'}} </text>
                <text class="td">{{item.prismDirection || '-'}} </text>
              </view>
            </block>
          </view>
        </block>
        <view class="divider"></view>
        <view class="sub-title">诊断与建议</view>
        <view class="grid">
          <view class="cell"><text class="label">诊断</text><text class="value">{{sheetTwo.visionTestResults.diagnosisName || '-'}}</text></view>
          <view class="cell"><text class="label">异常</text><text class="value">{{sheetTwo.visionTestResults.diagnosisAbnormal || '-'}}</text></view>
          <view class="cell"><text class="label">建议方案</text><text class="value">{{sheetTwo.visionTestResults.suggestions || sheetTwo.visionTestResults.sugggestions || '-'}}</text></view>
        </view>
      </block>
    </view>
  </block>
</view>
