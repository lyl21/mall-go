.page { padding: 12px; }
.loading { color: #888; font-size: 14px; padding: 16px; text-align: center; }
.section { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 12px; margin-bottom: 12px; }
.section-header { display: flex; justify-content: space-between; align-items: center; }
.section-title { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.sub-title { font-size: 14px; color: #666; margin: 8px 0; }
.grid { display: grid; grid-template-columns: 1fr 1fr; grid-gap: 8px; }
.cell { display: flex; justify-content: space-between; }
.label { color: #666; }
.value { color: #333; }
.table { width: 100%; }
.thead, .tr { display: grid; grid-template-columns: 1.2fr 1fr 1fr; }
.th, .td { padding: 6px 4px; border-bottom: 1px solid #f0f0f0; }
.thead .th { font-weight: 600; color: #333; }
/* segmented toggle */
.segmented { display: flex; gap: 8px; margin: 8px 0 12px; }
.segment { padding: 6px 12px; border: 1px solid #ddd; border-radius: 16px; color: #666; }
.segment.active { background: #1989fa; border-color: #1989fa; color: #fff; }
/* section divider */
.divider { height: 1px; background: #eee; margin: 12px 0; }

.ai-content { font-size: 14px; color: #333; line-height: 1.6; white-space: pre-wrap; }
.more-btn { font-size: 14px; color: #1989fa; padding: 4px 0 4px 12px; }

/* try optometry summary table with more columns */
.table-try .thead, .table-try .tr {
  display: grid;
  grid-template-columns: 0.9fr 1fr 1fr 1fr 1fr 1fr 1fr 1fr;
}
/* allow values to wrap for readability */
.td { word-break: break-word; white-space: normal; }
